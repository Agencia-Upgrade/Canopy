# =============================================================================
# Canopy — environment template
# Developed by Agência Upgrade — https://agenciaupgrade.com.br
#
# Copy this file to `.env` and fill it in. `.env` is never committed.
# `make setup` does this for you (copies the file and generates the salts).
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# Defaults below match docker-compose.yml — change both if you change either.
# -----------------------------------------------------------------------------
DB_NAME='canopy_local'
DB_USER='dev'
DB_PASSWORD='dev'
DB_HOST='db'

# Alternative: a single DSN instead of the four variables above.
# When set, DB_NAME / DB_USER / DB_PASSWORD / DB_HOST are ignored.
# DATABASE_URL='mysql://database_user:database_password@database_host:database_port/database_name'

# Table prefix (default 'wp_').
# DB_PREFIX='wp_'

# -----------------------------------------------------------------------------
# Environment & URLs
# WP_ENV selects which config/environments/{WP_ENV}.php file loads — it is the
# switch between development, staging and production behavior (debug, cache).
# -----------------------------------------------------------------------------
WP_ENV='development'
WP_HOME='http://localhost:8080'
WP_SITEURL="${WP_HOME}/wp"

# Path for the debug log (used when WP_ENV=development).
# WP_DEBUG_LOG='/path/to/debug.log'

# -----------------------------------------------------------------------------
# Authentication keys & salts
# Generate a fresh set at https://roots.io/salts.html (`make setup` does this).
# -----------------------------------------------------------------------------
AUTH_KEY='generateme'
SECURE_AUTH_KEY='generateme'
LOGGED_IN_KEY='generateme'
NONCE_KEY='generateme'
AUTH_SALT='generateme'
SECURE_AUTH_SALT='generateme'
LOGGED_IN_SALT='generateme'
NONCE_SALT='generateme'

# -----------------------------------------------------------------------------
# Redis object cache — requires the redis-cache plugin to be active.
# In Docker, the host is the compose service name ('redis').
# -----------------------------------------------------------------------------
WP_REDIS_HOST='redis'
WP_REDIS_PORT='6379'

# -----------------------------------------------------------------------------
# Cloudflare Images — base URL for image transformations (optional).
# -----------------------------------------------------------------------------
# CF_IMAGES_URL='https://imagedelivery.net/your-account-hash'

# -----------------------------------------------------------------------------
# SMTP — transactional email.
# Leave blank in development; Mailpit catches mail on port 1025.
# In production, fill these with your provider's credentials.
# -----------------------------------------------------------------------------
SMTP_HOST=''
SMTP_PORT='465'
SMTP_ENCRYPTION='ssl'
SMTP_USER=''
SMTP_PASS=''
SMTP_FROM='noreply@yourdomain.com'
SMTP_FROM_NAME='Your Site'
