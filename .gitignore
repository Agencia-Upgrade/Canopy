# Canopy
# Agência Upgrade — https://agenciaupgrade.com.br

# Credenciais — nunca versionar
.env
.env.*
!.env.example
auth.json

# WordPress core — instalado via Composer (roots/wordpress)
/web/wp

# Plugins — instalados via Composer
/web/app/plugins/*
!/web/app/plugins/.gitkeep

# MU-plugins — instalados via Composer (type:wordpress-muplugin → diretório)
/web/app/mu-plugins/bedrock-disallow-indexing/

# Uploads e arquivos gerados pelo WordPress
/web/app/uploads/*
!/web/app/uploads/.gitkeep
/web/app/upgrade
/web/app/languages/
/web/app/litespeed/

# Twig cache
/web/app/themes/*/cache

# Dependências PHP
/vendor

# PHPStan cache
/tmp/

# Logs
*.log

# Claude Code
/skills-lock.json
/.claude/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
/base/