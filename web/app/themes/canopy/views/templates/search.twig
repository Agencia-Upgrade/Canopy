{# Search Results #}

{% extends "layouts/base.twig" %}

{% block content %}
	<div class="cnp-search">
		<header class="cnp-search__header">
			{# search_query is user input — escape it. #}
			<h1 class="cnp-search__title">{{ __('Search results for', 'canopy') }} "{{ search_query|e }}"</h1>
		</header>

		{% if posts %}
			<div class="cnp-search__list">
				{% for post in posts %}
					<article class="cnp-search__item">
						<h2 class="cnp-search__item-title">
							<a href="{{ post.link }}">{{ post.title }}</a>
						</h2>
						<p class="cnp-search__item-excerpt">{{ post.excerpt }}</p>
						<a href="{{ post.link }}" class="cnp-search__item-link">{{ __('Read more →', 'canopy') }}</a>
					</article>
				{% endfor %}
			</div>

			{% include 'partials/pagination.twig' %}
		{% else %}
			<p class="cnp-search__no-results">{{ __('No results found.', 'canopy') }}</p>
		{% endif %}
	</div>
{% endblock %}
