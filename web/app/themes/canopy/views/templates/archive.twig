{# Archive #}

{% extends "layouts/base.twig" %}

{% block content %}
	<div class="cnp-archive">
		<header class="cnp-archive__header">
			<h1 class="cnp-archive__title">{{ wp_title }}</h1>
		</header>

		<div class="cnp-archive__list">
			{% for post in posts %}
				<article class="cnp-archive__item">
					<h2 class="cnp-archive__item-title">
						<a href="{{ post.link }}">{{ post.title }}</a>
					</h2>
					<p class="cnp-archive__item-excerpt">{{ post.excerpt }}</p>
					<a href="{{ post.link }}" class="cnp-archive__item-link">Read more →</a>
				</article>
			{% endfor %}
		</div>
	</div>
{% endblock %}
