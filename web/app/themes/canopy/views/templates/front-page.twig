{# Front Page #}

{% extends "layouts/base.twig" %}

{% block content %}
	<div class="cnp-hero">
		<div class="cnp-hero__inner">
			<h1 class="cnp-hero__title">Welcome to {{ site.name }}</h1>
			<p class="cnp-hero__subtitle">Built with Canopy — Bedrock + Timber</p>
		</div>
	</div>

	{% if post.content %}
		<div class="cnp-container">
			{# Example island: the reveal component loads its JS (and Motion) on demand. #}
			{% embed 'components/reveal.twig' %}
				{% block reveal %}
					{# post.content is sanitized by WordPress; raw keeps the HTML markup. Do not use raw on unfiltered input. #}
					{{ post.content|raw }}
				{% endblock %}
			{% endembed %}
		</div>
	{% endif %}
{% endblock %}
