{# 404 Not Found #}

{% extends "layouts/base.twig" %}

{% block content %}
	<div class="cnp-error-404">
		<h1 class="cnp-error-404__title">{{ __('404 — Page Not Found', 'canopy') }}</h1>
		<p class="cnp-error-404__message">{{ __('Sorry, we couldn\'t find the page you\'re looking for.', 'canopy') }}</p>
		<a href="{{ site.url }}" class="cnp-error-404__link">{{ __('Back to Home →', 'canopy') }}</a>
	</div>
{% endblock %}
